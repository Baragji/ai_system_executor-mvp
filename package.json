{
  "name": "executor-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "clean-output": "rimraf output && mkdir -p output",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:debug": "playwright test --debug",
    "test:lighthouse": "node scripts/run-lhci.mjs",
    "validate:ui": "npm run test:ui && npm run test:lighthouse",
    "ui:test": "playwright test -c playwright.config.ts",
    "contract:check": "node scripts/validate-contract.js",
    "sbom": "npm sbom --sbom-format=spdx --omit=dev > sbom.spdx.json",
    "validate:all": "npm run lint && npm run typecheck && npm test && npm run contract:check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.5",
    "diff": "^5.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "openai": "^4.57.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.11.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.0",
    "@types/cors": "^2.8.17",
    "@types/diff": "^7.0.2",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.7",
    "@types/node": "^22.5.4",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.11.0",
    "globals": "^15.9.0",
    "wait-on": "^7.2.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20.10.0 <21"
  }
}
