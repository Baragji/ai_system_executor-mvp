+// --- Fix A: context-aware per-entry detector for state:next / auto-update path ---
+export async function detectEvidenceForEntryWithContext(entry, { recentLimit = 200 } = {}) {
+  // Merge the current entry with the recent history, then run the standard detector.
+  const history = await loadRecentEntries(recentLimit);
+  const merged = [];
+  const seen = new Set();
+  function pushUnique(e) {
+    if (!e) return;
+    const k = `${e.timestamp ?? ""}|${e.source ?? ""}|${normalizeCommand(e.command ?? "")}`;
+    if (seen.has(k)) return;
+    seen.add(k);
+    merged.push(e);
+  }
+  for (const h of history) pushUnique(h);
+  pushUnique(entry);
+  return detectEvidence(merged, { latestPerCriterion: true });
+}
+
