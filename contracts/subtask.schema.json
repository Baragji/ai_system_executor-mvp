{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://executor-mvp/contracts/subtask.schema.json",
  "title": "Subtask",
  "type": "object",
  "required": ["id", "title", "description", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 3,
      "maxLength": 60
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "failed"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "uniqueItems": true,
      "default": []
    },
    "estimatedComplexity": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "successCriteria": {
      "type": "string",
      "minLength": 5,
      "maxLength": 500
    }
  },
  "additionalProperties": false
}
