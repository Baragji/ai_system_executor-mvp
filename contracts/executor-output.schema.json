{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutorOutput",
  "type": "object",
  "properties": {
    "project_name": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Posix-style relative path under project root",
            "pattern": "^(?!/|\\\\\\\\|[A-Za-z]:|\\.|\\.\\.).*"
          },
          "contents": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "contents"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hasTests": {
      "type": "boolean",
      "description": "Indicates whether at least one test file exists in the generated output"
    },
    "clarification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "asked": {
          "type": "boolean"
        },
        "questions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/clarificationQuestion"
          }
        },
        "answers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/clarificationAnswer"
          }
        },
        "improvedSuccess": {
          "type": "boolean"
        }
      },
      "required": [
        "asked",
        "questions",
        "answers",
        "improvedSuccess"
      ]
    },
    "repairMetrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalAttempts": { "type": "integer", "minimum": 0, "maximum": 4 },
        "successAttempt": { "anyOf": [
          { "type": "integer", "minimum": 1, "maximum": 4 },
          { "type": "null" }
        ] },
        "timePerAttempt": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "maxItems": 4
        },
        "failureTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exhausted": { "type": "boolean" },
        "attemptEfficiency": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": [
        "totalAttempts",
        "timePerAttempt",
        "failureTypes",
        "exhausted",
        "attemptEfficiency"
      ]
    }
  },
  "required": [
    "files",
    "hasTests"
  ],
  "additionalProperties": false,
  "definitions": {
    "clarificationQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "choice",
            "text",
            "number"
          ]
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "default": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "choice"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "properties": {
              "options": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1
              }
            },
            "required": [
              "options"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "enum": [
                  "text",
                  "number"
                ]
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "required": [
                "options"
              ]
            }
          }
        }
      ]
    },
    "clarificationAnswer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questionId",
        "value"
      ],
      "properties": {
        "questionId": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        }
      }
    }
  }
}
