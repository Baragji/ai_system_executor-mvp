{
  "contract_version": "2.1.0",
  "contract_meta": {
    "created": "2025-10-05",
    "phase": "2A",
    "phase_name": "Interactive Clarification - Detection & Question Generation",
    "prerequisite_phase": "Phase 1 (self-testing loop complete)",
    "rationale": "Phase 2 split into 3 contracts to manage complexity. 2A establishes backend clarification system before UI integration.",
    "references": [
      "Azure AI Foundry Agent Observability (2025)",
      "Phase 2 Roadmap Document"
    ]
  },
  "project": {
    "name": "executor-mvp",
    "current_phase": "2A",
    "goal": "Implement backend clarification system: detect missing info, generate questions, expose API endpoint. No UI changes in this phase.",
    "scope": "Wins 10-13 only",
    "out_of_scope": [
      "UI clarification flow (Phase 2B)",
      "Prompt augmentation (Phase 2B)",
      "Execute flow integration (Phase 2B)",
      "Telemetry updates (Phase 2C)",
      "Smart defaults (Phase 2C)"
    ]
  },
  "execution_model": {
    "type": "autonomous_with_verification",
    "verification_strategy": "observe_evaluate_proceed",
    "description": "Agent verifies Phase 1 completion, then builds Phase 2A incrementally with testing after each win.",
    "failure_mode": "halt_and_report",
    "no_assumptions": true
  },
  "environments": {
    "dev": {
      "node_version": ">=20.10.0 <21",
      "package_manager": "npm",
      "os": "linux|macos",
      "env_vars_required": [],
      "optional_env_vars": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY"],
      "verify_commands": [
        {
          "cmd": "node -v",
          "expect_regex": "^v20\\.",
          "on_fail": "Install Node.js 20.x (LTS) before proceeding."
        },
        {
          "cmd": "npm -v",
          "expect_exit_code": 0
        }
      ]
    }
  },
  "observability": {
    "description": "Continues 2025 agent observability pillars from Phase 1",
    "trace_file": ".automation/execution_trace.jsonl",
    "evaluation_file": ".automation/evaluation_results.json",
    "monitoring": {
      "task_status_tracking": true,
      "verification_pass_fail": true,
      "elapsed_time_per_task": true
    },
    "logging": {
      "format": "jsonl",
      "fields": ["timestamp", "task_id", "action", "status", "cmd", "exit_code", "stdout_excerpt", "stderr_excerpt"]
    },
    "evaluation": {
      "continuous": true,
      "evaluate_after_each_win": true,
      "quality_dimensions": ["correctness", "completeness", "safety"]
    },
    "governance": {
      "halt_on_security_violation": true,
      "require_explicit_verification": true,
      "no_destructive_operations_without_confirmation": true
    }
  },
  "global_quality_standards": {
    "lint": {
      "command": "npm run lint",
      "must_pass": true,
      "max_warnings": 0
    },
    "typecheck": {
      "command": "npm run typecheck",
      "must_pass": true
    },
    "tests": {
      "command": "npm test",
      "expected": {
        "exit_code": 0,
        "no_failed_suites": true
      },
      "coverage": {
        "min_line_pct": 80,
        "min_branch_pct": 75
      }
    },
    "schemas": {
      "ajv_strict": true,
      "draft_version": "2020-12"
    }
  },
  "high_level_stages": [
    "phase1_verification",
    "contracts_definition",
    "detection_logic",
    "question_generation",
    "api_exposure",
    "phase2a_validation"
  ],
  "tasks": [
    {
      "id": "P1-V01",
      "stage": "phase1_verification",
      "title": "Verify Phase 1 completion",
      "type": "verification",
      "description": "Confirm Phase 1 artifacts exist and system is functional before starting Phase 2A",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "test -f contracts/run-result.schema.json && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "test -f src/repair/repairOnce.ts && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "test -f tests/e2e/phase1.test.ts && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "npm test 2>&1 | tail -5",
          "capture_output": true,
          "expect_exit_code": 0
        }
      ],
      "evaluation": {
        "intent": "Verify Phase 1 complete before starting Phase 2A",
        "success_criteria": "All Phase 1 artifacts exist and tests pass",
        "on_fail": "HALT - Phase 1 must be complete before Phase 2A"
      },
      "trace_context": {
        "decision_point": "phase1_verification",
        "reasoning_required": true,
        "critical": true
      }
    },
    {
      "id": "W10",
      "stage": "contracts_definition",
      "title": "Win #10: Define Clarification Contracts",
      "type": "win",
      "description": "Create clarification-request.schema.json and clarification-response.schema.json",
      "time_estimate_minutes": 40,
      "actions": [
        {
          "type": "create_file",
          "file": "contracts/clarification-request.schema.json",
          "content_spec": {
            "schema_structure": {
              "type": "object",
              "required": ["questions"],
              "properties": {
                "questions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "text", "type"],
                    "properties": {
                      "id": {"type": "string"},
                      "text": {"type": "string"},
                      "type": {"type": "string", "enum": ["choice", "text", "number"]},
                      "options": {"type": "array", "items": {"type": "string"}}
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        {
          "type": "create_file",
          "file": "contracts/clarification-response.schema.json",
          "content_spec": {
            "schema_structure": {
              "type": "object",
              "required": ["answers"],
              "properties": {
                "answers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["questionId", "value"],
                    "properties": {
                      "questionId": {"type": "string"},
                      "value": {"type": ["string", "number"]}
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        {
          "type": "create_validators",
          "file": "src/contracts/clarificationValidators.ts",
          "ensure": ["import both schemas", "export validateClarificationRequest", "export validateClarificationResponse", "use Ajv strict mode"]
        },
        {
          "type": "create_tests",
          "file": "tests/contracts/clarification-schemas.test.ts",
          "test_cases": [
            "valid request with choice question",
            "valid request with text question",
            "valid request with number question",
            "invalid request missing required field",
            "invalid request with unknown question type",
            "valid response with string answer",
            "valid response with number answer",
            "invalid response missing questionId",
            "invalid response with mismatched questionId",
            "empty questions array (valid edge case)"
          ]
        }
      ],
      "validation": [
        {
          "cmd": "test -f contracts/clarification-request.schema.json",
          "expect_exit_code": 0
        },
        {
          "cmd": "test -f contracts/clarification-response.schema.json",
          "expect_exit_code": 0
        },
        {
          "cmd": "grep -q 'validateClarificationRequest' src/contracts/clarificationValidators.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm test -- clarification-schemas.test.ts",
          "expect_exit_code": 0
        }
      ],
      "success_criteria": [
        "Both schema files exist and are valid JSON",
        "Validators compile without errors",
        "All 10 test cases pass",
        "Schemas use additionalProperties: false",
        "Draft 2020-12 compliant"
      ],
      "trace_context": {
        "decision_point": "contracts_created",
        "win_number": 10
      }
    },
    {
      "id": "W11",
      "stage": "detection_logic",
      "title": "Win #11: Critical Info Detector",
      "type": "win",
      "description": "Create detectMissing.ts that analyzes prompts for missing critical information",
      "time_estimate_minutes": 45,
      "actions": [
        {
          "type": "create_file",
          "file": "src/clarification/detectMissing.ts",
          "content_spec": {
            "function_signature": "export function detectMissing(prompt: string): string[]",
            "critical_info_types": ["framework", "port", "database", "authentication", "styling", "testFramework"],
            "detection_logic": "Keyword-based scanning for each info type. Return array of missing types.",
            "examples": [
              "Input: 'build me an API' -> Output: ['framework', 'port', 'database']",
              "Input: 'build me a Flask API on port 8000' -> Output: ['database']",
              "Input: 'build me a FastAPI with PostgreSQL auth on 8000' -> Output: []"
            ]
          }
        },
        {
          "type": "create_tests",
          "file": "tests/clarification/detectMissing.test.ts",
          "test_cases": [
            "complete prompt (nothing missing) - should return []",
            "prompt missing framework - should return ['framework']",
            "prompt missing port - should return ['port']",
            "prompt missing database - should return ['database']",
            "prompt missing authentication - should return ['authentication']",
            "prompt missing multiple items - should return all missing"
          ]
        }
      ],
      "validation": [
        {
          "cmd": "test -f src/clarification/detectMissing.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "grep -q 'export function detectMissing' src/clarification/detectMissing.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm test -- detectMissing.test.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "success_criteria": [
        "Function correctly identifies all 6 critical info types",
        "Returns empty array for complete prompts",
        "Returns specific missing items for incomplete prompts",
        "All 6 test cases pass",
        "TypeScript compiles without errors"
      ],
      "trace_context": {
        "decision_point": "detection_logic_implemented",
        "win_number": 11
      }
    },
    {
      "id": "W12",
      "stage": "question_generation",
      "title": "Win #12: Question Generator",
      "type": "win",
      "description": "Create generateQuestions.ts that converts missing info types into specific questions",
      "time_estimate_minutes": 45,
      "actions": [
        {
          "type": "create_file",
          "file": "src/clarification/generateQuestions.ts",
          "content_spec": {
            "function_signature": "export function generateQuestions(missingTypes: string[]): ClarificationRequest",
            "question_templates": {
              "framework": {
                "id": "framework",
                "text": "Which framework would you like to use?",
                "type": "choice",
                "options": ["Flask", "FastAPI", "Express", "Django"]
              },
              "port": {
                "id": "port",
                "text": "Which port should the server run on?",
                "type": "number",
                "default": 8000
              },
              "database": {
                "id": "database",
                "text": "Which database would you like to use?",
                "type": "choice",
                "options": ["PostgreSQL", "MySQL", "SQLite", "None"]
              },
              "authentication": {
                "id": "authentication",
                "text": "Do you need authentication?",
                "type": "choice",
                "options": ["Yes", "No"]
              },
              "styling": {
                "id": "styling",
                "text": "Which CSS framework would you like?",
                "type": "choice",
                "options": ["Tailwind", "Bootstrap", "Plain CSS", "None"]
              },
              "testFramework": {
                "id": "testFramework",
                "text": "Which test framework would you like?",
                "type": "choice",
                "options": ["Pytest", "Jest", "Vitest", "Mocha"]
              }
            },
            "return_format": "Return ClarificationRequest matching schema from Win #10"
          }
        },
        {
          "type": "create_tests",
          "file": "tests/clarification/generateQuestions.test.ts",
          "test_cases": [
            "generate question for 'framework' type",
            "generate question for 'port' type",
            "generate question for 'database' type",
            "generate question for 'authentication' type",
            "generate questions for multiple types",
            "validate output matches clarification-request schema"
          ]
        }
      ],
      "validation": [
        {
          "cmd": "test -f src/clarification/generateQuestions.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "grep -q 'export function generateQuestions' src/clarification/generateQuestions.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm test -- generateQuestions.test.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "success_criteria": [
        "All 6 info types have question templates",
        "Generated questions match clarification-request schema",
        "Questions are clear and concise",
        "All test cases pass",
        "Schema validation passes for generated output"
      ],
      "trace_context": {
        "decision_point": "question_generation_implemented",
        "win_number": 12
      }
    },
    {
      "id": "W13",
      "stage": "api_exposure",
      "title": "Win #13: API Endpoint for Clarification",
      "type": "win",
      "description": "Add POST /api/clarify endpoint that detects missing info and returns questions",
      "time_estimate_minutes": 40,
      "actions": [
        {
          "type": "add_route",
          "file": "src/server.ts",
          "route_spec": {
            "method": "POST",
            "path": "/api/clarify",
            "request_body": {"prompt": "string"},
            "response": "ClarificationRequest (from Win #10)",
            "logic": [
              "Extract prompt from request body",
              "Call detectMissing(prompt) from Win #11",
              "Call generateQuestions(missingTypes) from Win #12",
              "Validate response against clarification-request schema",
              "Return questions JSON"
            ]
          }
        },
        {
          "type": "create_tests",
          "file": "tests/api/clarify-route.test.ts",
          "test_cases": [
            "complete prompt - should return empty questions array",
            "incomplete prompt - should return questions",
            "invalid request body - should return 400 error",
            "response matches clarification-request schema"
          ]
        }
      ],
      "validation": [
        {
          "cmd": "grep -q '/api/clarify' src/server.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm test -- clarify-route.test.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "success_criteria": [
        "Endpoint responds to POST requests",
        "Returns valid clarification-request JSON",
        "Empty questions for complete prompts",
        "Proper questions for incomplete prompts",
        "All integration tests pass"
      ],
      "trace_context": {
        "decision_point": "api_endpoint_created",
        "win_number": 13
      }
    },
    {
      "id": "P2A-GATE",
      "stage": "phase2a_validation",
      "title": "Phase 2A validation gate",
      "type": "validation",
      "description": "Final validation that Phase 2A backend is complete before moving to Phase 2B (UI integration)",
      "actions": [
        {
          "type": "validate",
          "cmd": "npm run lint",
          "expect_exit_code": 0
        },
        {
          "type": "validate",
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        },
        {
          "type": "validate",
          "cmd": "npm test",
          "expect_exit_code": 0
        },
        {
          "type": "validate",
          "cmd": "test -f contracts/clarification-request.schema.json && test -f contracts/clarification-response.schema.json",
          "expect_exit_code": 0
        },
        {
          "type": "validate",
          "cmd": "test -f src/clarification/detectMissing.ts && test -f src/clarification/generateQuestions.ts",
          "expect_exit_code": 0
        },
        {
          "type": "manual_test",
          "description": "Manual verification: POST to /api/clarify with 'build me an API' should return questions for framework, port, database"
        }
      ],
      "evaluation": {
        "intent": "Confirm Phase 2A backend is production-ready before UI integration",
        "success_criteria": "All tests pass, schemas valid, API endpoint functional, manual test passes",
        "on_pass": "Phase 2A COMPLETE - Ready for Phase 2B",
        "on_fail": "HALT - Fix issues before proceeding to Phase 2B"
      },
      "trace_context": {
        "decision_point": "phase2a_gate",
        "reasoning_required": true,
        "critical": true,
        "gate_type": "go_no_go"
      }
    }
  ],
  "execution_order": [
    "P1-V01",
    "W10",
    "W11",
    "W12",
    "W13",
    "P2A-GATE"
  ],
  "execution_semantics": {
    "win_isolation": {
      "description": "Each win must be complete and tested before proceeding to next",
      "implementation": "Run full test suite after each win. Halt if any test fails."
    },
    "gate_enforcement": {
      "P2A-GATE": {
        "required": true,
        "on_fail": "HALT execution. Do not proceed to Phase 2B.",
        "report": "Generate diagnostic report showing which validations failed and why."
      }
    },
    "no_ui_changes": {
      "enforcement": "Phase 2A makes ZERO changes to public/ directory",
      "rationale": "UI integration is Phase 2B. Keep concerns separated."
    }
  },
  "completion_criteria": {
    "phase1_verified": true,
    "contracts_created": true,
    "detection_logic_works": true,
    "question_generation_works": true,
    "api_endpoint_functional": true,
    "all_tests_pass": true,
    "coverage_maintained": true,
    "manual_test_passes": true
  },
  "fallback_policies": {
    "phase1_verification_fails": "HALT - Phase 1 must be complete. Review Phase 1 contract execution.",
    "schema_validation_fails": "Revert schema file, fix syntax, re-run validation.",
    "test_fails": "Fix implementation, do not skip tests.",
    "coverage_drops": "Add tests to maintain >80% coverage before proceeding."
  },
  "reporting": {
    "progress_file": ".automation/progress_phase2a.json",
    "fields": ["task_id", "win_number", "status", "started_at", "finished_at", "elapsed_ms", "result", "errors"],
    "status_values": ["pending", "running", "success", "failed", "skipped"],
    "phase2a_report": {
      "file": ".automation/phase2a_completion_report.json",
      "fields": ["wins_completed", "gate_passed", "timestamp", "next_phase", "diagnostics"]
    }
  },
  "final_artifacts_verification": [
    {
      "name": "Clarification Request Schema",
      "path": "contracts/clarification-request.schema.json",
      "must_include_regex": "questions"
    },
    {
      "name": "Clarification Response Schema",
      "path": "contracts/clarification-response.schema.json",
      "must_include_regex": "answers"
    },
    {
      "name": "Detection Module",
      "path": "src/clarification/detectMissing.ts",
      "must_include_regex": "export function detectMissing"
    },
    {
      "name": "Question Generator",
      "path": "src/clarification/generateQuestions.ts",
      "must_include_regex": "export function generateQuestions"
    },
    {
      "name": "Phase 2A Report",
      "path": ".automation/phase2a_completion_report.json",
      "must_exist": true,
      "must_include_field": "gate_passed"
    }
  ],
  "release_actions": [
    {
      "cmd": "git add .",
      "expect_exit_code": 0
    },
    {
      "cmd": "git commit -m \"feat(phase2a): implement clarification backend - detection, question generation, API endpoint\"",
      "expect_exit_code": 0
    },
    {
      "cmd": "git tag phase2a-complete",
      "expect_exit_code": 0
    }
  ],
  "ai_executor_guidelines": {
    "observability_first": "Trace all decisions. Log reasoning for each win completion.",
    "win_isolation": "Complete and test each win fully before proceeding to next. Do not mix wins.",
    "no_ui_changes": "Phase 2A is backend-only. Do not modify public/ directory.",
    "test_driven": "Write tests before or alongside implementation. Never skip tests.",
    "fail_fast": "If any test fails, halt and fix before proceeding.",
    "gate_enforcement": "P2A-GATE must pass before declaring phase complete."
  }
}