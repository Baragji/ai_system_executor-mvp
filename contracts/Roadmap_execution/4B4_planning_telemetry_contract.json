    { "id": "W50", "stage": "trace_schema", "title": "Win #50: Add execution-trace schema + validator", "type": "win", "description": "Create contracts/execution-trace.schema.json and validator to assert JSONL entries.", "time_estimate_minutes": 45, "actions": [ { "type": "create_file", "file": "contracts/execution-trace.schema.json", "content_spec": { "type": "object", "required": ["timestamp", "task_id", "action", "status"], "properties": { "timestamp": {"type":"string"}, "task_id": {"type":"string"}, "action": {"type":"string"}, "status": {"type":"string"}, "subtask_id": {"type":"string"}, "progress_pct": {"type":"number"} }, "additionalProperties": true } }, { "type": "create_file", "file": "src/contracts/executionTraceValidator.ts", "content_spec": "Ajv 2020 validator for execution-trace.schema.json; export validateExecutionTrace(entry)" }, { "type": "create_tests", "file": "tests/contracts/execution-trace.test.ts", "content_spec": "Valid and invalid entries inc. subtask_id/progress_pct" } ], "validation": [ { "cmd": "test -f contracts/execution-trace.schema.json", "expect_exit_code": 0 }, { "cmd": "test -f src/contracts/executionTraceValidator.ts", "expect_exit_code": 0 }, { "cmd": "npm test -- execution-trace.test.ts", "expect_exit_code": 0 }, { "cmd": "npm run typecheck", "expect_exit_code": 0 } ], "success_criteria": ["Schema and validator exist", "Tests pass", "TypeScript compiles without errors"], "trace_context": { "decision_point": "trace_schema_added", "win_number": 50 } },
