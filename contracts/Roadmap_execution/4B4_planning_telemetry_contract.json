    { "id": "W52", "stage": "tests", "title": "Win #52: Plan progress trace tests", "type": "win", "description": "Add tests to emit plan_progress and validate trace entries via validator.", "time_estimate_minutes": 45, "actions": [ { "type": "create_tests", "file": "tests/telemetry/plan-trace.test.ts", "content_spec": "Use temp cwd; call logEvent('plan_progress',{subtask:'s1', status:'in_progress', percent:50}); read trace file; validate with validator" } ], "validation": [ { "cmd": "npm test -- plan-trace.test.ts", "expect_exit_code": 0 }, { "cmd": "npm run typecheck", "expect_exit_code": 0 } ], "success_criteria": ["Plan progress events produce valid trace lines", "subtask_id/progress_pct present", "All tests pass", "TypeScript compiles without errors"], "trace_context": { "decision_point": "trace_tests", "win_number": 52 } },
