{
  "contract_version": "2.0.0",
  "contract_meta": {
    "created": "2025-10-05",
    "rationale": "Phase 0 verification required before Phase 1 execution. Uses 2025 AI agent observability patterns: continuous monitoring, tracing, evaluation, and governance.",
    "references": [
      "Azure AI Foundry Agent Observability (2025)",
      "Agentic AI Workflow Patterns (MarkTechPost, Aug 2025)",
      "AI Agent Ethical Framework 2025"
    ]
  },
  "project": {
    "name": "executor-mvp",
    "goal": "Elevate current MVP to production-grade Phase 1: stable self-testing loop (single repair attempt), unified schemas, green tests, UI test controls, metadata and audit trail.",
    "current_state": "Post-corruption revert to first commit (Phase 0 foundation)",
    "out_of_scope": [
      "Multi-turn repair (Phase 3)",
      "Advanced planning (Phase 4)",
      "Persistent memory / preference learning (Phase 5)",
      "Authentication / external DB",
      "Cloud deployment beyond local Node start script"
    ]
  },
  "execution_model": {
    "type": "autonomous_with_verification",
    "verification_strategy": "observe_evaluate_proceed",
    "description": "Agent observes system state, evaluates against expected conditions, proceeds only on verification pass. Aligns with 2025 agent observability best practices.",
    "failure_mode": "halt_and_report",
    "no_assumptions": true
  },
  "environments": {
    "dev": {
      "node_version": ">=20.10.0 <21",
      "package_manager": "npm",
      "os": "linux|macos",
      "env_vars_required": [],
      "optional_env_vars": ["OPENAI_API_KEY", "ANTHROPIC_API_KEY"],
      "verify_commands": [
        {
          "cmd": "node -v",
          "expect_regex": "^v20\\.",
          "on_fail": "Install Node.js 20.x (LTS) before proceeding."
        },
        {
          "cmd": "npm -v",
          "expect_exit_code": 0
        }
      ]
    }
  },
  "observability": {
    "description": "Implements 2025 agent observability pillars: monitoring, tracing, logging, evaluation, governance",
    "trace_file": ".automation/execution_trace.jsonl",
    "evaluation_file": ".automation/evaluation_results.json",
    "monitoring": {
      "task_status_tracking": true,
      "verification_pass_fail": true,
      "elapsed_time_per_task": true
    },
    "logging": {
      "format": "jsonl",
      "fields": ["timestamp", "task_id", "action", "status", "cmd", "exit_code", "stdout_excerpt", "stderr_excerpt"]
    },
    "evaluation": {
      "continuous": true,
      "evaluate_after_each_task": true,
      "quality_dimensions": ["correctness", "completeness", "safety"]
    },
    "governance": {
      "halt_on_security_violation": true,
      "require_explicit_verification": true,
      "no_destructive_operations_without_confirmation": true
    }
  },
  "global_quality_standards": {
    "lint": {
      "command": "npm run lint",
      "must_pass": true,
      "max_warnings": 0
    },
    "typecheck": {
      "command": "npm run typecheck",
      "must_pass": true
    },
    "tests": {
      "command": "npm test",
      "expected": {
        "exit_code": 0,
        "no_failed_suites": true
      },
      "coverage": {
        "min_line_pct": 80,
        "min_branch_pct": 75
      }
    },
    "schemas": {
      "ajv_strict": true,
      "draft_version": "2020-12"
    },
    "security": {
      "sandbox_time_limit_ms": 60000,
      "sandbox_cpu_limit_secs": 60,
      "sandbox_file_size_limit_mb": 100,
      "forbidden_network": true,
      "path_escape_disallowed": true
    },
    "ui": {
      "manual_run_tests_button": true,
      "automatic_execute_triggers_initial_tests": true,
      "repair_timeline_visible": true,
      "log_view_expandable": true
    },
    "metadata": {
      "meta_file": "_executor_meta.json",
      "must_include": [
        "created_at",
        "source_prompt",
        "notes",
        "testRuns",
        "files"
      ],
      "file_checksum_algo": "sha256"
    },
    "repair": {
      "single_attempt_only": true,
      "diff_format": "overwrite_file_set",
      "record_artifacts": true
    }
  },
  "artifacts_contracts": {
    "run_result": {
      "file": "contracts/run-result.schema.json",
      "required_fields": ["status", "passCount", "failCount", "durationMs", "logsPath", "timestamp"],
      "status_enum": ["pass", "fail", "error"],
      "extended_optional_fields": ["command", "exitCode", "signal", "timedOut", "errorMessage", "startedAt", "finishedAt"],
      "production_rules": [
        "No trailing commas",
        "additionalProperties: false except when design explicitly needs an extensibility object",
        "Time fields ISO 8601"
      ]
    },
    "executor_output": {
      "file": "contracts/executor-output.schema.json",
      "required_fields": ["files", "hasTests"],
      "test_file_path_patterns": ["^tests/", "^__tests__/"],
      "must_reject_no_test_files": true
    },
    "repair_artifact": {
      "file": "contracts/repair-artifact.schema.json",
      "required_fields": ["path", "action"],
      "action_enum": ["modify", "add", "delete"],
      "description_optional": true
    },
    "meta_file_structure": {
      "file_name": "_executor_meta.json",
      "fields": ["created_at", "source_prompt", "notes", "testRuns", "repair", "files"],
      "testRuns_item": ["attempt", "status", "passCount", "failCount", "durationMs", "logsPath", "timestamp"],
      "files_item": ["path", "sha256"]
    }
  },
  "high_level_stages": [
    "phase0_verification",
    "phase0_remediation",
    "phase0_validation",
    "environment_verification",
    "schema_unification",
    "runner_consolidation",
    "api_alignment",
    "ui_enhancements",
    "repair_implementation",
    "metadata_enrichment",
    "telemetry_addition",
    "e2e_flow_test",
    "hardening_and_cleanup",
    "final_validation"
  ],
  "tasks": [
    {
      "id": "P0-V01",
      "stage": "phase0_verification",
      "title": "Verify Phase 0: Project structure exists",
      "type": "verification",
      "description": "Observe repository state. Verify foundational files and directories exist.",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "test -f package.json && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "test -d src && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "test -d public && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "test -f tsconfig.json && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        }
      ],
      "evaluation": {
        "intent": "Verify basic Phase 0 structure is present",
        "success_criteria": "All expected files/directories exist",
        "on_fail": "Proceed to P0-R01 (remediation)"
      },
      "trace_context": {
        "decision_point": "structure_verification",
        "reasoning_required": true
      }
    },
    {
      "id": "P0-V02",
      "stage": "phase0_verification",
      "title": "Verify Phase 0: Dependencies installable",
      "type": "verification",
      "description": "Attempt to install dependencies. Verify package.json is valid and dependencies resolve.",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "npm ci --dry-run 2>&1 || npm install --dry-run 2>&1",
          "capture_output": true,
          "timeout_ms": 30000,
          "expect_exit_code": 0
        }
      ],
      "evaluation": {
        "intent": "Verify dependency resolution works",
        "success_criteria": "npm can resolve and install dependencies without errors",
        "on_fail": "Proceed to P0-R02 (fix package.json)"
      },
      "trace_context": {
        "decision_point": "dependency_verification",
        "reasoning_required": true
      }
    },
    {
      "id": "P0-V03",
      "stage": "phase0_verification",
      "title": "Verify Phase 0: Core server module exists",
      "type": "verification",
      "description": "Verify src/server.ts or equivalent entry point exists",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "test -f src/server.ts && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        }
      ],
      "evaluation": {
        "intent": "Verify server entry point exists",
        "success_criteria": "src/server.ts file exists",
        "on_fail": "Proceed to P0-R03 (create minimal server)"
      },
      "trace_context": {
        "decision_point": "server_module_verification",
        "reasoning_required": true
      }
    },
    {
      "id": "P0-V04",
      "stage": "phase0_verification",
      "title": "Verify Phase 0: UI files exist",
      "type": "verification",
      "description": "Verify public/index.html and public/script.js exist",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "test -f public/index.html && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        },
        {
          "type": "observe",
          "cmd": "test -f public/script.js && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "expect_stdout": "exists"
        }
      ],
      "evaluation": {
        "intent": "Verify UI files exist",
        "success_criteria": "Both index.html and script.js exist",
        "on_fail": "Proceed to P0-R04 (create minimal UI)"
      },
      "trace_context": {
        "decision_point": "ui_verification",
        "reasoning_required": true
      }
    },
    {
      "id": "P0-V05",
      "stage": "phase0_verification",
      "title": "Verify Phase 0: LLM integration exists",
      "type": "verification",
      "description": "Verify executor module that calls LLM exists",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "find src -name '*executor*' -o -name '*generate*' | head -1",
          "capture_output": true,
          "expect_nonempty_stdout": true
        }
      ],
      "evaluation": {
        "intent": "Verify LLM integration module exists",
        "success_criteria": "At least one file matching executor/generate pattern exists",
        "on_fail": "Proceed to P0-R05 (create executor module)"
      },
      "trace_context": {
        "decision_point": "llm_integration_verification",
        "reasoning_required": true
      }
    },
    {
      "id": "P0-V06",
      "stage": "phase0_verification",
      "title": "Verify Phase 0: Output directory exists",
      "type": "verification",
      "description": "Verify output directory exists for generated files",
      "verification_mode": "observe_only",
      "actions": [
        {
          "type": "observe",
          "cmd": "test -d output && echo 'exists' || echo 'missing'",
          "capture_output": true,
          "allow_missing": true
        }
      ],
      "evaluation": {
        "intent": "Verify output directory exists",
        "success_criteria": "output directory exists OR can be created",
        "on_fail": "Proceed to P0-R06 (create output directory)"
      },
      "trace_context": {
        "decision_point": "output_dir_verification",
        "reasoning_required": false
      }
    },
    {
      "id": "P0-EVAL",
      "stage": "phase0_verification",
      "title": "Evaluate Phase 0 verification results",
      "type": "evaluation",
      "description": "Analyze all Phase 0 verification task results. Determine if remediation needed.",
      "actions": [
        {
          "type": "evaluate",
          "evaluate_tasks": ["P0-V01", "P0-V02", "P0-V03", "P0-V04", "P0-V05", "P0-V06"],
          "evaluation_logic": "all_must_pass",
          "on_all_pass": "Skip to P0-GATE (Phase 0 complete)",
          "on_any_fail": "Proceed to phase0_remediation stage"
        }
      ],
      "trace_context": {
        "decision_point": "phase0_complete_or_remediate",
        "reasoning_required": true,
        "critical": true
      }
    },
    {
      "id": "P0-R01",
      "stage": "phase0_remediation",
      "title": "Remediate: Create missing project structure",
      "type": "remediation",
      "conditional": "only_if_P0-V01_failed",
      "description": "Create missing directories and base files",
      "actions": [
        {
          "type": "create_if_missing",
          "cmd": "mkdir -p src public tests contracts .automation",
          "expect_exit_code": 0
        },
        {
          "type": "create_if_missing",
          "cmd": "test -f package.json || npm init -y",
          "expect_exit_code": 0
        },
        {
          "type": "create_if_missing",
          "cmd": "test -f tsconfig.json || npx tsc --init",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "test -d src && test -d public && test -f package.json",
          "expect_exit_code": 0
        }
      ],
      "trace_context": {
        "decision_point": "structure_creation",
        "action_taken": "create_directories_and_files"
      }
    },
    {
      "id": "P0-R02",
      "stage": "phase0_remediation",
      "title": "Remediate: Fix package.json dependencies",
      "type": "remediation",
      "conditional": "only_if_P0-V02_failed",
      "description": "Ensure package.json has valid dependencies for Phase 0",
      "actions": [
        {
          "type": "install",
          "cmd": "npm install express typescript ts-node @types/node @types/express vitest ajv",
          "expect_exit_code": 0,
          "timeout_ms": 120000
        }
      ],
      "validation": [
        {
          "cmd": "npm ls express typescript ajv",
          "expect_exit_code": 0
        }
      ],
      "trace_context": {
        "decision_point": "dependency_installation",
        "action_taken": "install_core_dependencies"
      }
    },
    {
      "id": "P0-R03",
      "stage": "phase0_remediation",
      "title": "Remediate: Create minimal server",
      "type": "remediation",
      "conditional": "only_if_P0-V03_failed",
      "description": "Create minimal Express server at src/server.ts",
      "actions": [
        {
          "type": "create_file",
          "file": "src/server.ts",
          "content_spec": "Minimal Express server with /api/execute endpoint that accepts POST with {prompt: string}, returns {status: string}. Port 3000. TypeScript."
        }
      ],
      "validation": [
        {
          "cmd": "grep -q 'express' src/server.ts",
          "expect_exit_code": 0
        },
        {
          "cmd": "grep -q '/api/execute' src/server.ts",
          "expect_exit_code": 0
        }
      ],
      "trace_context": {
        "decision_point": "server_creation",
        "action_taken": "create_minimal_express_server"
      }
    },
    {
      "id": "P0-R04",
      "stage": "phase0_remediation",
      "title": "Remediate: Create minimal UI",
      "type": "remediation",
      "conditional": "only_if_P0-V04_failed",
      "description": "Create minimal UI with prompt input and execute button",
      "actions": [
        {
          "type": "create_file",
          "file": "public/index.html",
          "content_spec": "HTML page with textarea for prompt, 'Execute' button, results display area"
        },
        {
          "type": "create_file",
          "file": "public/script.js",
          "content_spec": "JavaScript that POSTs to /api/execute, displays response"
        }
      ],
      "validation": [
        {
          "cmd": "grep -q '<textarea' public/index.html",
          "expect_exit_code": 0
        },
        {
          "cmd": "grep -q 'fetch.*api/execute' public/script.js",
          "expect_exit_code": 0
        }
      ],
      "trace_context": {
        "decision_point": "ui_creation",
        "action_taken": "create_minimal_ui_files"
      }
    },
    {
      "id": "P0-R05",
      "stage": "phase0_remediation",
      "title": "Remediate: Create executor module",
      "type": "remediation",
      "conditional": "only_if_P0-V05_failed",
      "description": "Create module that calls LLM and returns JSON",
      "actions": [
        {
          "type": "create_file",
          "file": "src/executor/generate.ts",
          "content_spec": "Function generateFromPrompt(prompt: string) that calls OpenAI/Anthropic API, returns {files: Array<{path: string, content: string}>}. TypeScript. Use OPENAI_API_KEY from env."
        }
      ],
      "validation": [
        {
          "cmd": "test -f src/executor/generate.ts",
          "expect_exit_code": 0
        }
      ],
      "trace_context": {
        "decision_point": "executor_creation",
        "action_taken": "create_llm_integration_module"
      }
    },
    {
      "id": "P0-R06",
      "stage": "phase0_remediation",
      "title": "Remediate: Create output directory",
      "type": "remediation",
      "conditional": "only_if_P0-V06_failed",
      "description": "Create output directory for generated files",
      "actions": [
        {
          "type": "create_directory",
          "cmd": "mkdir -p output",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "test -d output",
          "expect_exit_code": 0
        }
      ],
      "trace_context": {
        "decision_point": "output_dir_creation",
        "action_taken": "create_output_directory"
      }
    },
    {
      "id": "P0-GATE",
      "stage": "phase0_validation",
      "title": "Phase 0 validation gate",
      "type": "validation",
      "description": "Final validation that Phase 0 is complete and functional before proceeding to Phase 1",
      "actions": [
        {
          "type": "validate",
          "cmd": "npm ci || npm install",
          "expect_exit_code": 0,
          "timeout_ms": 120000
        },
        {
          "type": "validate",
          "cmd": "npm run typecheck || npx tsc --noEmit",
          "expect_exit_code": 0,
          "allow_warnings": true
        },
        {
          "type": "validate",
          "cmd": "test -d output && test -f src/server.ts && test -f public/index.html",
          "expect_exit_code": 0
        }
      ],
      "evaluation": {
        "intent": "Confirm Phase 0 is production-ready",
        "success_criteria": "Dependencies installed, TypeScript compiles, all critical files exist",
        "on_pass": "Proceed to Phase 1 (T01)",
        "on_fail": "HALT - Report Phase 0 validation failure with diagnostics"
      },
      "trace_context": {
        "decision_point": "phase0_gate",
        "reasoning_required": true,
        "critical": true,
        "gate_type": "go_no_go"
      }
    },
    {
      "id": "T01",
      "stage": "environment_verification",
      "title": "Install dependencies",
      "type": "phase1_task",
      "requires": "P0-GATE_passed",
      "actions": [
        {
          "cmd": "npm ci || npm install",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "node -v",
          "expect_regex": "^v20\\."
        },
        {
          "cmd": "npm ls ajv",
          "expect_regex": "ajv@"
        }
      ],
      "fallback": "Reinstall Node 20 LTS, clear node_modules (rm -rf node_modules package-lock.json) then npm install."
    },
    {
      "id": "T02",
      "stage": "schema_unification",
      "title": "Fix run-result schema JSON correctness",
      "type": "phase1_task",
      "actions": [
        {
          "edit": "contracts/run-result.schema.json",
          "ensure": ["no trailing commas", "additionalProperties false", "align field names with interface"]
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "node -e \"const s=require('./contracts/run-result.schema.json');console.log('ok')\"",
          "expect_stdout_regex": "ok"
        }
      ],
      "fallback": "Restore last working version from VCS and reapply minimal patch."
    },
    {
      "id": "T03",
      "stage": "schema_unification",
      "title": "Create/align TypeScript RunResult interface",
      "type": "phase1_task",
      "actions": [
        {
          "edit": "src/contracts/validators.ts",
          "ensure": ["interface includes extended optional fields", "strict mode compile passes"]
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "grep -n \"passCount\" src/contracts/validators.ts",
          "expect_exit_code": 0
        }
      ],
      "fallback": "Revert file and re-add fields incrementally."
    },
    {
      "id": "T04",
      "stage": "runner_consolidation",
      "title": "Remove duplicate runner and export single canonical module",
      "type": "phase1_task",
      "actions": [
        {
          "cmd": "test -f runInSandbox.ts && echo exists",
          "expect_stdout_regex": "exists"
        },
        {
          "cmd": "test -f runInSandbox.ts && mv runInSandbox.ts src/runner/LEGACY_runInSandbox.ts || true"
        },
        {
          "edit": "src/server.ts",
          "ensure": ["import { runInSandbox } from '../runner/runInSandbox.js'"]
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "grep -n \"runInSandbox\" src/server.ts",
          "expect_exit_code": 0
        }
      ],
      "fallback": "If removal breaks build, restore backup and diff functions to manually merge logic."
    },
    {
      "id": "T05",
      "stage": "runner_consolidation",
      "title": "Enhance runInSandbox to compute pass/fail counts from log",
      "type": "phase1_task",
      "actions": [
        {
          "edit": "src/runner/runInSandbox.ts",
          "add_logic": "parse summary lines to set passCount/failCount, default 0 if unknown"
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "grep -n \"passCount\" src/runner/runInSandbox.ts",
          "expect_exit_code": 0
        }
      ],
      "fallback": "If parsing unreliable, keep counts at 0 and mark TODO; do not block main pipeline (but record deviation)."
    },
    {
      "id": "T06",
      "stage": "api_alignment",
      "title": "Align /api/run-tests response to unified schema",
      "type": "phase1_task",
      "actions": [
        {
          "edit": "src/server.ts",
          "ensure": ["validate run result centrally", "return schema-compliant JSON"]
        },
        {
          "cmd": "npm run typecheck",
          "expect_exit_code": 0
        }
      ],
      "validation": [
        {
          "cmd": "node -e \"fetch('http://localhost:3000/healthz').catch(()=>0)\" || true",
          "expect_exit_code": 0
        }
      ],
      "fallback": "If refactor complex, introduce adapter function mapping internal->public DSL."
    },
    {
      "id": "T07",
      "stage": "api_alignment",
      "title": "Repair failing integration test expectations",
      "type": "phase1_task",
      "actions": [
        {
          "edit": "tests/run-tests-route.test.ts",
          "replace_expectations": "use schema fields (status, passCount, failCount, durationMs, logsPath, timestamp)"
        },
        {
          "cmd": "npm test --silent || true"
        }
      ],
      "validation": [
        {
          "cmd": "grep -n \"passCount\" tests/run-tests-route.test.ts",
          "expect_exit_code": 0
        }
      ],
      "fallback": "If tests rely on legacy fields, add those fields as derived but keep canonical schema validated."
    },
    {
      "id": "T08",
      "stage": "ui_enhancements",
