+
+    const bulletMatch = trimmed.match(/^-+\s*(✅|🟡|⏳|❌|☑️|⚪️|🔲|▪️|✳️|⬜️|➡️)?\s*(.*)$/u);
+    if (!bulletMatch) {
+      continue;
+    }
+
+    const status = bulletMatch[1] ?? "";
