+    if (!text) {
+      continue;
+    }
+
+    index[currentGate].push({
+      gateId: currentGate,
+      text,
+      status,
+      lineNumber: i + 1
+    });
+  }
+
+  return index;
+}
+
+export function loadGateCriteria(options = {}) {
+  const { ledgerPath = LEDGER_PATH, force = false } = options;
