+  }
+
+  const criteria = loadGateCriteria({ ledgerPath })[gateId];
+  if (!criteria) {
+    return undefined;
+  }
+
+  return criteria.find(entry => includes.every(token => entry.text.includes(token)));
+}
+
+export function requireCriterion(options) {
+  const found = findCriterion(options);
