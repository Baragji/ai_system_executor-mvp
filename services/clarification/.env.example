# Default port for the clarification service
PORT=3007

# Enable to export traces through the OTLP HTTP exporter
OTEL_ENABLED=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional override for telemetry resource attributes
SERVICE_NAME=executor-clarification-service

# Enable RFC 9457 problem+json responses (auto-enabled in dev/test)
PROBLEM_DETAILS_ENABLED=1
